@page
@model PakkaHisaab.Admin.Pages.Attendance.IndexModel
@{ ViewData["PageTitle"] = "Attendance"; }

<div class="ph-card mb-3">
    <div class="ph-card-body py-3">
        <form class="row g-2 align-items-center" method="get">
            <div class="col-sm-3">
                <input type="search" name="q" value="@Model.Q" class="form-control form-control-sm" placeholder="Search helper or owner email…" />
            </div>
            <div class="col-sm-2">
                <select name="status" class="form-select form-select-sm">
                    <option value="">All statuses</option>
                    @foreach (var s in Model.Statuses)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <input type="date" name="from" value="@Model.From" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <input type="date" name="to" value="@Model.To" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <button type="submit" class="btn btn-sm btn-ph-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="ph-card">
    <div class="table-responsive">
        <table class="table ph-table mb-0">
            <thead><tr><th>Date</th><th>Helper</th><th>Owner</th><th>Status</th><th>Units</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var a in Model.Rows)
                {
                    <tr>
                        <td>@a.Date</td>
                        <td class="fw-semibold">@a.HelperName</td>
                        <td class="text-secondary">@a.OwnerEmail</td>
                        <td>
                            @{ var b = PakkaHisaab.Admin.Helpers.Badge.Attendance(a.Status); }
                            <ph-badge text="@b.Text" kind="@b.Kind" />
                        </td>
                        <td>@(a.UnitsDelivered > 0 ? a.UnitsDelivered.ToString("N2") : "—")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-confirm-action="?handler=Remove&id=@a.Id&@Model.QueryString&page=@Model.Page"
                                    data-confirm-title="Remove this entry?"
                                    data-confirm-body="The attendance record for @a.Date will be removed and synced to the owner's app."
                                    data-confirm-button="Remove">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Rows.Any())
                {
                    <tr><td colspan="6" class="text-center text-secondary py-4">No attendance entries match this filter.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="ph-card-body pt-0">
        <partial name="_Pagination" model="@(new PakkaHisaab.Admin.Models.PaginationModel { Page = Model.Page, TotalPages = Model.TotalPages, QueryString = Model.QueryString })" />
    </div>
</div>

<partial name="_ConfirmModal" />
