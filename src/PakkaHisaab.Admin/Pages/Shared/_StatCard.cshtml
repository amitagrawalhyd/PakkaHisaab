@model PakkaHisaab.Admin.Models.StatCardModel
<div class="ph-stat">
    <div>
        <div class="ph-stat-label">@Model.Label</div>
        <div class="ph-stat-value">@Model.Value</div>
        @if (!string.IsNullOrEmpty(Model.Sub))
        {
            <div class="ph-stat-sub">@Model.Sub</div>
        }
    </div>
    <div class="ph-stat-icon @Model.Color">
        <i class="bi @Model.Icon"></i>
    </div>
</div>
