@page
@model PakkaHisaab.Admin.Pages.Ledger.IndexModel
@{ ViewData["PageTitle"] = "Ledger Entries"; }

<div class="ph-card mb-3">
    <div class="ph-card-body py-3">
        <form class="row g-2 align-items-center" method="get">
            <div class="col-sm-4">
                <input type="search" name="q" value="@Model.Q" class="form-control form-control-sm" placeholder="Search helper or owner email…" />
            </div>
            <div class="col-sm-3">
                <select name="type" class="form-select form-select-sm">
                    <option value="">All types</option>
                    @foreach (var t in Model.Types)
                    {
                        <option value="@t" selected="@(Model.Type == t)">@t</option>
                    }
                </select>
            </div>
            <div class="col-sm-3">
                <input type="month" name="period" value="@Model.Period" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <button type="submit" class="btn btn-sm btn-ph-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="ph-card">
    <div class="table-responsive">
        <table class="table ph-table mb-0">
            <thead><tr><th>Date</th><th>Helper</th><th>Owner</th><th>Type</th><th>Amount</th><th>Method</th><th>Note</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var l in Model.Rows)
                {
                    <tr>
                        <td class="text-secondary">@l.OccurredAtUtc.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@l.HelperName</td>
                        <td class="text-secondary">@l.OwnerEmail</td>
                        <td>
                            @{ var tb = PakkaHisaab.Admin.Helpers.Badge.LedgerType(l.Type); }
                            <ph-badge text="@tb.Text" kind="@tb.Kind" />
                        </td>
                        <td class="fw-semibold">₹@l.Amount.ToString("N2")</td>
                        <td>
                            @{ var mb = PakkaHisaab.Admin.Helpers.Badge.Method(l.Method); }
                            <ph-badge text="@mb.Text" kind="@mb.Kind" />
                        </td>
                        <td class="text-secondary small">@(l.Note ?? "—")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-confirm-action="?handler=Remove&id=@l.Id&@Model.QueryString&page=@Model.Page"
                                    data-confirm-title="Remove this ledger entry?"
                                    data-confirm-body="This ₹@l.Amount.ToString("N2") @l.Type.ToString().ToLower() entry for @l.HelperName will be removed and synced to the owner's app."
                                    data-confirm-button="Remove">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Rows.Any())
                {
                    <tr><td colspan="8" class="text-center text-secondary py-4">No ledger entries match this filter.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="ph-card-body pt-0">
        <partial name="_Pagination" model="@(new PakkaHisaab.Admin.Models.PaginationModel { Page = Model.Page, TotalPages = Model.TotalPages, QueryString = Model.QueryString })" />
    </div>
</div>

<partial name="_ConfirmModal" />
