<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PakkaHisaab.Maui.ViewModels"
             xmlns:helpers="clr-namespace:PakkaHisaab.Maui.Helpers"
             x:Class="PakkaHisaab.Maui.Views.LedgerPage"
             x:DataType="vm:LedgerViewModel"
             Title="{Binding HelperName}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding GoHomeCommand}" />
    </Shell.BackButtonBehavior>

    <Grid>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Border Style="{StaticResource Card}" BackgroundColor="#F0FDFA">
                <Grid ColumnDefinitions="*,Auto">
                    <Label VerticalOptions="Center" FontFamily="{DynamicResource FontSemiBold}"
                           Text="{helpers:Translate Ledger_AdvancesThisMonth}" />
                    <Label Grid.Column="1" Style="{StaticResource TitleLabel}" FontSize="20"
                           TextColor="{StaticResource Primary}" Text="{Binding AdvanceTotal}" />
                </Grid>
            </Border>

            <CollectionView ItemsSource="{Binding Entries}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center"
                           Padding="0,40" Text="{helpers:Translate Ledger_Empty}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LedgerRow">
                        <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                                <Label FontFamily="{DynamicResource FontSemiBold}" Text="{Binding TypeLabel}" />
                                <Label Grid.Row="1" Style="{StaticResource MutedLabel}" Text="{Binding DateLabel}" />
                                <Label Grid.Column="1" Grid.RowSpan="2" VerticalOptions="Center"
                                       FontFamily="{DynamicResource FontBold}" FontSize="16"
                                       TextColor="{StaticResource TextPrimary}"
                                       Text="{Binding AmountLabel}" />
                                <Label Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource IconLabel}"
                                       Margin="10,0,0,0" TextColor="{StaticResource Danger}"
                                       Text="{x:Static helpers:IconFont.Delete}"
                                       AutomationProperties.Name="{helpers:Translate Common_Delete}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LedgerViewModel}}, Path=DeleteEntryCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- FAB: log a cash advance -->
        <Button Text="{x:Static helpers:IconFont.Add}" FontFamily="MaterialIcons" FontSize="26"
                WidthRequest="60" HeightRequest="60" CornerRadius="30"
                HorizontalOptions="End" VerticalOptions="End" Margin="0,0,22,22"
                BackgroundColor="{StaticResource Secondary}"
                Command="{Binding OpenSheetCommand}" />

        <!-- Bottom-sheet modal for a new entry -->
        <Border IsVisible="{Binding IsSheetOpen}"
                VerticalOptions="End" StrokeThickness="0"
                BackgroundColor="{StaticResource Surface}"
                StrokeShape="RoundRectangle 24,24,0,0" Padding="24,18,24,34">
            <Border.Shadow>
                <Shadow Brush="#1E293B" Opacity="0.25" Radius="30" Offset="0,-6" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="14">
                <BoxView WidthRequest="42" HeightRequest="4" CornerRadius="2"
                         Color="{StaticResource Outline}" HorizontalOptions="Center" />
                <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Ledger_NewEntry}" />

                <Border Style="{StaticResource InputBorder}">
                    <Picker ItemsSource="{Binding EntryTypes}" SelectedItem="{Binding SelectedType}" />
                </Border>
                <Border Style="{StaticResource InputBorder}">
                    <Entry Placeholder="{helpers:Translate Ledger_Amount}" Keyboard="Numeric"
                           Text="{Binding Amount}" />
                </Border>
                <Border Style="{StaticResource InputBorder}">
                    <Entry Placeholder="{helpers:Translate Ledger_Note}" Text="{Binding Note}" />
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Text="{helpers:Translate Common_Cancel}" Command="{Binding CloseSheetCommand}" />
                    <Button Grid.Column="1" Text="{helpers:Translate Common_Save}"
                            Command="{Binding SaveEntryCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
