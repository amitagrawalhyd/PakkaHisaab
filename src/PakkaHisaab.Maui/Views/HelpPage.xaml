<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:PakkaHisaab.Maui.Helpers"
             x:Class="PakkaHisaab.Maui.Views.HelpPage"
             Title="{helpers:Translate Settings_HelpAndVoice}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Features -->
            <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Help_Features}" FontSize="20" />

            <VerticalStackLayout Spacing="10">
                <Label FontFamily="{DynamicResource FontSemiBold}" Text="{helpers:Translate Help_Home_Title}" />
                <Label Text="{helpers:Translate Help_Home_Body}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" Text="{helpers:Translate Help_Calendar_Title}" />
                <Label Text="{helpers:Translate Help_Calendar_Body}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" Text="{helpers:Translate Calendar_Ledger}" />
                <Label Text="{helpers:Translate Help_Ledger_Body}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" Text="{helpers:Translate Dash_Settle}" />
                <Label Text="{helpers:Translate Help_Settle_Body}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" Text="{helpers:Translate Reports_Title}" />
                <Label Text="{helpers:Translate Help_Reports_Body}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" Text="{helpers:Translate Help_EditDelete_Title}" />
                <Label Text="{helpers:Translate Help_EditDelete_Body}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" />

            <!-- Voice commands -->
            <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Help_VoiceCommands}" FontSize="20" />
            <Label TextColor="{StaticResource TextMuted}"
                   Text="{helpers:Translate Help_VoiceIntro}" />

            <VerticalStackLayout Spacing="10">
                <Label FontFamily="{DynamicResource FontSemiBold}" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate Help_Attendance_Title}" />
                <Label Text="{helpers:Translate Help_Attendance_Examples}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate Help_Delivery_Title}" />
                <Label Text="{helpers:Translate Help_Delivery_Examples}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate LedgerType_Advance}" />
                <Label Text="{helpers:Translate Help_Advance_Examples}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate LedgerType_Deduction}" />
                <Label Text="{helpers:Translate Help_Deduction_Examples}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate LedgerType_Bonus}" />
                <Label Text="{helpers:Translate Help_Bonus_Examples}" />

                <Label FontFamily="{DynamicResource FontSemiBold}" Margin="0,8,0,0" TextColor="{StaticResource Primary}"
                       Text="{helpers:Translate Help_Payment_Title}" />
                <Label Text="{helpers:Translate Help_Payment_Examples}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" />

            <Label TextColor="{StaticResource TextMuted}" FontSize="12"
                   Text="{helpers:Translate Help_Tip}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
