<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PakkaHisaab.Maui.ViewModels"
             xmlns:services="clr-namespace:PakkaHisaab.Maui.Services"
             xmlns:helpers="clr-namespace:PakkaHisaab.Maui.Helpers"
             x:Class="PakkaHisaab.Maui.Views.SettlementPage"
             x:DataType="vm:SettlementViewModel"
             Title="{helpers:Translate Settle_Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Style="{StaticResource TitleLabel}" Text="{Binding HelperName}" />
            <Label Style="{StaticResource MutedLabel}" Margin="0,-12,0,0" Text="{Binding PeriodLabel}" />

            <!-- Breakdown card: Wage − Unpaid Absences − Advances = Final Payable -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Style="{StaticResource MutedLabel}" FontSize="14" Text="{helpers:Translate Report_GrossWage}" />
                        <Label Grid.Column="1" Text="{Binding GrossLabel}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Style="{StaticResource MutedLabel}" FontSize="14" Text="{helpers:Translate Report_UnpaidAbsences}" />
                        <Label Grid.Column="1" TextColor="{StaticResource Danger}" Text="{Binding AbsenceLabel}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Style="{StaticResource MutedLabel}" FontSize="14" Text="{helpers:Translate Report_Advances}" />
                        <Label Grid.Column="1" TextColor="{StaticResource Danger}" Text="{Binding AdvanceLabel}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Outline}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label FontFamily="PoppinsBold" FontSize="16" Text="{helpers:Translate Report_FinalPayable}" />
                        <Label Grid.Column="1" FontFamily="PoppinsBold" FontSize="20"
                               TextColor="{StaticResource Primary}" Text="{Binding PayableLabel}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Manual amount amendment -->
            <Label Style="{StaticResource MutedLabel}" Text="{helpers:Translate Settle_AmountToPay}" />
            <Border Style="{StaticResource InputBorder}">
                <Entry Keyboard="Numeric" Text="{Binding AmountToPay}" FontSize="18" />
            </Border>

            <!-- UPI app grid (deep links via upi://pay) -->
            <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Settle_PayVia}"
                   IsVisible="{Binding HasUpiId}" />
            <CollectionView ItemsSource="{Binding UpiApps}" SelectionMode="None"
                            IsVisible="{Binding HasUpiId}" HeightRequest="110">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:UpiApp">
                        <Border Style="{StaticResource Card}" Padding="14" WidthRequest="104">
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{StaticResource IconLabel}" FontSize="30"
                                       TextColor="{StaticResource Secondary}"
                                       Text="{x:Static helpers:IconFont.Payments}" />
                                <Label FontSize="12" HorizontalTextAlignment="Center" Text="{Binding Name}" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding PayWithUpiCommand, Source={RelativeSource AncestorType={x:Type vm:SettlementViewModel}}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Style="{StaticResource MutedLabel}" FontSize="12"
                   IsVisible="{Binding HasUpiId, Converter={StaticResource InvertBool}}"
                   Text="{helpers:Translate Settle_NoUpiIdHint}" />

            <!-- Cash fallback -->
            <Button Style="{StaticResource SecondaryButton}"
                    Text="{helpers:Translate Settle_LogCash}"
                    Command="{Binding PayCashCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
