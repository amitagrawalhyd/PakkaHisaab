<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PakkaHisaab.Maui.ViewModels"
             xmlns:helpers="clr-namespace:PakkaHisaab.Maui.Helpers"
             x:Class="PakkaHisaab.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20,56,20,20" Spacing="16">

            <Label Style="{StaticResource TitleLabel}" Text="{helpers:Translate Settings_Title}" />

            <!-- Language: runtime switch, updates every binding instantly -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Style="{StaticResource IconLabel}" Text="{x:Static helpers:IconFont.Language}" />
                        <Label Grid.Column="1" Style="{StaticResource SectionLabel}" VerticalOptions="Center"
                               Text="{helpers:Translate Settings_Language}" />
                    </Grid>
                    <Border Style="{StaticResource InputBorder}">
                        <Picker ItemsSource="{Binding Languages}"
                                ItemDisplayBinding="{Binding NativeName}"
                                SelectedItem="{Binding SelectedLanguage}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Help -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Settings_Help}" />
                    <Label TextColor="{StaticResource Primary}" Text="{helpers:Translate Settings_HelpAndVoice}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenHelpCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Legal (App Store compliance) -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Settings_Legal}" />
                    <Label TextColor="{StaticResource Primary}" Text="{helpers:Translate Settings_Privacy}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenPrivacyCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label TextColor="{StaticResource Primary}" Text="{helpers:Translate Settings_Terms}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenTermsCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Account -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label Style="{StaticResource SectionLabel}" Text="{helpers:Translate Settings_Account}" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Text="{helpers:Translate Settings_Logout}"
                            Command="{Binding LogoutCommand}" />
                    <!-- "Delete My Account & Data" — required by both stores -->
                    <Button Style="{StaticResource DangerButton}"
                            Text="{helpers:Translate Settings_DeleteAccount}"
                            Command="{Binding DeleteAccountCommand}" />
                </VerticalStackLayout>
            </Border>

            <Label Style="{StaticResource MutedLabel}" FontSize="11" HorizontalTextAlignment="Center"
                   Text="PakkaHisaab · ClearKhata · v1.0.0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
