<?xml version="1.0" encoding="UTF-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Compile-time defaults for the Latin-only Poppins family. LocalizationResourceManager
         overrides these three keys at runtime (via DynamicResource) to null — the platform default
         font — for any language outside Poppins' Latin coverage, since iOS (unlike Android) does not
         automatically substitute a fallback font for glyphs missing from an embedded custom font. -->
    <x:String x:Key="FontRegular">PoppinsRegular</x:String>
    <x:String x:Key="FontSemiBold">PoppinsSemiBold</x:String>
    <x:String x:Key="FontBold">PoppinsBold</x:String>

    <!-- Typography -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{DynamicResource FontRegular}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="{DynamicResource FontBold}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="{DynamicResource FontSemiBold}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="IconLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="MaterialIcons" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{DynamicResource FontSemiBold}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{DynamicResource FontSemiBold}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="BorderColor" Value="{StaticResource Danger}" />
    </Style>

    <!-- Cards: clean, ample whitespace, soft shadow -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Stroke" Value="{StaticResource Outline}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#1E293B" Opacity="0.06" Radius="14" Offset="0,4" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Inputs -->
    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="{DynamicResource FontRegular}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource Outline}" />
        <Setter Property="StrokeThickness" Value="1.2" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>
</ResourceDictionary>
